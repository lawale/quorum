{
  "name": "@oluwavader/quorum-embed",
  "version": "0.0.1",
  "description": "Embeddable Web Components for the Quorum approval engine",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
