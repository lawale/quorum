<%- include('layout', { title: 'Dashboard', body: `

<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">Expense Dashboard</h1>
  <p class="mt-1 text-sm text-gray-500">Track and manage expense submissions requiring manager approval.</p>
</div>

${expenses.length === 0 ? `
<div class="text-center py-16">
  <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />
  </svg>
  <h3 class="mt-4 text-lg font-medium text-gray-900">No expenses yet</h3>
  <p class="mt-2 text-sm text-gray-500">Get started by submitting your first expense report.</p>
  <a href="/expense/new"
    class="mt-6 inline-flex items-center bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
    + New Expense
  </a>
</div>
` : `
<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  ${expenses.map(expense => `
  <a href="/expense/${expense.id}" class="block bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow p-5">
    <div class="flex items-start justify-between">
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-500 truncate">${expense.category}</p>
        <p class="mt-1 text-2xl font-bold text-gray-900">$${expense.amount.toFixed(2)}</p>
      </div>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
        ${expense.status === 'approved' ? 'bg-green-100 text-green-800' :
          expense.status === 'rejected' ? 'bg-red-100 text-red-800' :
          expense.status === 'pending' ? 'bg-yellow-100 text-yellow-800' :
          expense.status === 'cancelled' ? 'bg-gray-100 text-gray-600' :
          expense.status === 'expired' ? 'bg-orange-100 text-orange-800' :
          'bg-red-50 text-red-600'}">
        ${expense.status.charAt(0).toUpperCase() + expense.status.slice(1)}
      </span>
    </div>
    <div class="mt-4 space-y-1">
      <p class="text-sm text-gray-700 font-medium">${expense.employeeName}</p>
      ${expense.description ? `<p class="text-sm text-gray-500 truncate">${expense.description}</p>` : ''}
    </div>
    <div class="mt-3 pt-3 border-t border-gray-100">
      <p class="text-xs text-gray-400">${new Date(expense.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
    </div>
  </a>
  `).join('')}
</div>
`}

<!-- Quorum Approval Queue -->
<div class="mt-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-3">Approval Queue</h2>
  <p class="text-sm text-gray-500 mb-4">Live view of all expense approval requests tracked by Quorum.</p>
  <quorum-request-list
    api-url="${quorumUrl}"
    tenant-id="expenses"
    type="expense_approval"
    page-size="10"
    suppress-errors="true">
  </quorum-request-list>
</div>

<script>
  var quorumToLocal = {};
  ${expenses.filter(function(e) { return e.quorumRequestId; }).map(function(e) { return 'quorumToLocal["' + e.quorumRequestId + '"] = "' + e.id + '";'; }).join('\n  ')}
  document.addEventListener('DOMContentLoaded', function() {
    var p = window.__quorumProfile;
    if (p) {
      var headers = JSON.stringify({ 'X-User-Id': p.userId, 'X-User-Roles': p.roles });
      document.querySelector('quorum-request-list')?.setAttribute('auth-headers', headers);
    }
    var list = document.querySelector('quorum-request-list');
    list?.addEventListener('quorum:select', function(e) {
      var localId = quorumToLocal[e.detail.requestId];
      if (localId) window.location.href = '/expense/' + localId;
    });
    var s = document.createElement('script');
    s.src = '${quorumUrl}/assets/embed.js';
    document.body.appendChild(s);
  });
<\/script>

` }) %>
